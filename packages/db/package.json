{
  "name": "@bm/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema + migrations for the single shared PostgreSQL schema",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:deploy": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
